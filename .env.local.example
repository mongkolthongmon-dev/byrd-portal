# --- Database (Neon Postgres) ---
# Connection string from your Neon project dashboard.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- Auth.js (NextAuth v5) ---
# Secret used to sign session JWTs. Generate one with: npx auth secret
AUTH_SECRET="replace-with-a-long-random-string"
# Base URL of the app (used for OIDC callback URLs).
# Local: http://localhost:3000 — on Vercel this is set automatically.
AUTH_URL="http://localhost:3000"
# Allow OAuth/OIDC linking on a host Auth.js can't infer (e.g. behind a proxy).
AUTH_TRUST_HOST="true"

# --- Password hashing pepper (neon-dev style) ---
# Secret mixed into every password hash. Keep it out of the DB.
ENCODE_KEY="replace-with-a-long-random-string"

# --- Seed bootstrap (optional; used by scripts/seed.ts) ---
ADMIN_EMAIL="admin@byrd.local"
ADMIN_PASSWORD="ChangeMe123!"

# --- Public site config (NEXT_PUBLIC_* is exposed to the browser) ---
# Author/profile link shown in the footer.
NEXT_PUBLIC_AUTHOR_URL="https://my-profile-byrd.vercel.app"
